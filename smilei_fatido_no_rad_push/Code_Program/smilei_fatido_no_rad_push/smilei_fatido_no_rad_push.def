Bootstrap: localimage
From: /home/xuanwu/Code_Program/smilei_fatido_no_rad_push/smilei_fatido_no_rad_push_env.sif

%files

./smilei_fatido_no_rad_push.tar.gz /opt/.local/program/smilei_fatido_no_rad_push.tar.gz

%post

export HDF5_ROOT_DIR=/opt/.local/program/hdf5
export PYTHONEXE=python3

cd /opt/.local/program
tar -zxvf smilei_fatido_no_rad_push.tar.gz
rm smilei_fatido_no_rad_push.tar.gz

cd ./Smilei_FaTiDo_no_rad_push/
make -j32

# clean src
rm -rf \
  src \
  benchmarks \
  validation \
  doc \
  tools \
  scripts \
  makefile \
  CMakeLists.txt \
  .git \
  .github \
  .gitignore \
  .gitlab-ci.yml \
  License \
  README.md

%environment

export FI_PROVIDER=verbs
export I_MPI_FABRICS=shm:ofi
export LD_LIBRARY_PATH=/opt/.local/program/hdf5/lib:$LD_LIBRARY_PATH
export PATH=/opt/.local/program/Smilei_FaTiDo_no_rad_push:$PATH

%runscript

exec smilei "$@"

Bootstrap: localimage
From: /home/xuanwu/Code_Program/warpx_3d/warpx_env.sif

%files

./warpx_3d.tar.gz /opt/.local/program/warpx_3d.tar.gz

%post

export PYTHONEXE=python3

cd /opt/.local/program
tar -zxvf warpx_3d.tar.gz
rm warpx_3d.tar.gz

cd ./WarpX/
cmake -S . -B build \
  -DWarpX_MPI=ON \
  -DWarpX_PYTHON=ON \
  -DWarpX_DIMS="3" \
  -DCMAKE_INSTALL_PREFIX=/opt/warpx

cmake --build build -j 32

cmake --install build

# clean src
cd ..
rm -rf WarpX

%environment

export FI_PROVIDER=verbs
export I_MPI_FABRICS=shm:ofi
export PATH=/opt/warpx/bin:$PATH
export LD_LIBRARY_PATH=/opt/warpx/lib:$LD_LIBRARY_PATH

%runscript

exec warpx.3d.MPI.OMP.DP.PDP.OPMD.EB.QED "$@"

Bootstrap: docker
From: continuumio/miniconda3

%post

export DEBIAN_FRONTEND=noninteractive
export TZ=Asia/Shanghai
echo "tzdata tzdata/Areas select Asia" >timezone.txt
echo "tzdata tzdata/Zones/Asia select Shanghai" >>timezone.txt
debconf-set-selections timezone.txt
echo "Asia/Shanghai" >/etc/timezone
rm -f timezone.txt

set -eux

mkdir -p /etc/conda

cat >/etc/conda/.condarc <<'EOF'
channels:
  - conda-forge
channel_priority: strict
auto_activate_base: false
EOF

conda create -y -n warpx-cpu-mpich-dev \
  -c conda-forge \
  blaspp \
  boost \
  ccache \
  cmake \
  compilers \
  git \
  lapackpp \
  "openpmd-api=*=mpi_mpich*" \
  openpmd-viewer \
  packaging \
  pytest \
  python \
  python-build \
  make \
  numpy \
  pandas \
  scipy \
  setuptools \
  yt \
  "fftw=*=mpi_mpich*" \
  pkg-config \
  matplotlib \
  mamba \
  mpich \
  mpi4py \
  ninja \
  pip \
  virtualenv \
  wheel \
  llvm-openmp

conda clean --all --yes

rm -rf /opt/conda/pkgs/*.tar.bz2 || true

rm -rf /opt/conda/share/doc /opt/conda/share/man || true

%environment

export PATH="/opt/conda/envs/warpx-cpu-mpich-dev/bin:${PATH}"
export CONDA_ALWAYS_YES="true"
export CONDA_ROOT="/opt/conda"
export FI_PROVIDER=verbs
export I_MPI_FABRICS=shm:ofi
export LD_LIBRARY_PATH=/opt/.local/program/hdf5/lib:$LD_LIBRARY_PATH

%runscript

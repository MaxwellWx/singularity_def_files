Bootstrap: localimage
From: /home/xuanwu/Code_Program/warpx/warpx_env

%files

./warpx.tar.gz /opt/.local/program/warpx.tar.gz

%post

export PYTHONEXE=python3

export PATH="/opt/conda/envs/warpx-cpu-mpich-dev/bin:${PATH}"
pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple

cd /opt/.local/program
tar -zxvf warpx.tar.gz
rm warpx.tar.gz
cd ./WarpX/

cmake -S . -B build \
  -DWarpX_MPI=ON \
  -DWarpX_PYTHON=ON \
  -DWarpX_DIMS="1;2;3;RZ;RCYLINDER;RSPHERE" \
  -DCMAKE_INSTALL_PREFIX=/opt/warpx

cmake --build build -j 32

cmake --build build --target pip_install -j 32

cmake --install build

cd ..
rm -rf WarpX

%environment

export FI_PROVIDER=verbs
export I_MPI_FABRICS=shm:ofi
export PATH=/opt/warpx/bin:$PATH
export LD_LIBRARY_PATH=/opt/warpx/lib:$LD_LIBRARY_PATH

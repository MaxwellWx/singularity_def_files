Bootstrap: docker
From: ubuntu:20.04

%post

export DEBIAN_FRONTEND=noninteractive
export TZ=Asia/Shanghai
echo "tzdata tzdata/Areas select Asia" >timezone.txt
echo "tzdata tzdata/Zones/Asia select Shanghai" >>timezone.txt
debconf-set-selections timezone.txt
echo "Asia/Shanghai" >/etc/timezone
rm -f timezone.txt

apt-get update && apt-get install -y \
  build-essential \
  git \
  make \
  cmake \
  gcc \
  mpich \
  libmpich-dev \
  wget \
  openssh-client \
  zlib1g-dev \
  python3 \
  python3-pip

pip install numpy scipy -i https://pypi.tuna.tsinghua.edu.cn/simple

mkdir -p /opt/.local/program/source_code/
cd /opt/.local/program/source_code/
wget https://github.com/HDFGroup/hdf5/releases/download/hdf5_1.14.5/hdf5-1.14.5.tar.gz
tar -zxvf hdf5-1.14.5.tar.gz
rm hdf5-1.14.5.tar.gz

cd ./hdf5-1.14.5/
./configure --prefix=/opt/.local/program/hdf5 --enable-parallel \
  --with-pic --enable-shared --enable-build-mode=production \
  --disable-sharedlib-rpath --enable-static CC=mpicc FC=mpif90
make -j32
make install

%environment

export FI_PROVIDER=verbs
export I_MPI_FABRICS=shm:ofi
export LD_LIBRARY_PATH=/opt/.local/program/hdf5/lib:$LD_LIBRARY_PATH

%runscript

BootStrap: docker
From: ubuntu:20.04

%environment

# Intel MPI env variables
export FI_PROVIDER=verbs
export I_MPI_FABRICS=shm:ofi

%files

%post

# areas setup
export DEBIAN_FRONTEND=noninteractive
export TZ=Asia/Shanghai
echo "tzdata tzdata/Areas select Asia" >timezone.txt
echo "tzdata tzdata/Zones/Asia select Shanghai" >>timezone.txt
debconf-set-selections timezone.txt
echo "Asia/Shanghai" >/etc/timezone
rm -f timezone.txt

# install basic component
apt-get update -y
apt-get install -y \
  build-essential \
  make \
  cmake \
  gcc \
  libmpich-dev \
  mpich \
  python3 \
  python3-dev \
  python3-pip

# install python pkg
pip3 install --no-cache-dir --no-binary=mpi4py numpy scipy mpi4py h5py pybind11 nuitka  patchelf

# clean cache
apt-get clean
apt-get autoclean

%runscript
